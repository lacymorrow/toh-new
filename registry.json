{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "shipkit",
  "homepage": "https://shipkit.io",
  "items": [
    {
      "name": "cn",
      "type": "registry:lib",
      "title": "cn",
      "description": "Utility for merging Tailwind CSS classes with clsx and tailwind-merge.",
      "files": [
        {
          "path": "src/lib/utils/cn.ts",
          "type": "registry:lib",
          "target": "~/lib/utils/cn.ts"
        }
      ],
      "dependencies": ["clsx", "tailwind-merge"]
    },
    {
      "name": "marquee",
      "type": "registry:ui",
      "title": "Marquee",
      "description": "An infinite scrolling marquee component with horizontal and vertical support.",
      "files": [
        {
          "path": "src/components/ui/marquee.tsx",
          "type": "registry:ui"
        }
      ],
      "registryDependencies": ["cn"],
      "tailwind": {
        "config": {
          "theme": {
            "extend": {
              "keyframes": {
                "marquee": {
                  "from": { "transform": "translateX(0)" },
                  "to": { "transform": "translateX(calc(-100% - var(--gap)))" }
                },
                "marquee-vertical": {
                  "from": { "transform": "translateY(0)" },
                  "to": { "transform": "translateY(calc(-100% - var(--gap)))" }
                }
              },
              "animation": {
                "marquee": "marquee var(--duration) infinite linear",
                "marquee-vertical": "marquee-vertical var(--duration) linear infinite"
              }
            }
          }
        }
      }
    },
    {
      "name": "border-beam",
      "type": "registry:ui",
      "title": "Border Beam",
      "description": "An animated beam effect that traces along the border of a container.",
      "files": [
        {
          "path": "src/components/ui/border-beam.tsx",
          "type": "registry:ui"
        }
      ],
      "registryDependencies": ["cn"],
      "tailwind": {
        "config": {
          "theme": {
            "extend": {
              "keyframes": {
                "border-beam": {
                  "100%": { "offset-distance": "100%" }
                }
              },
              "animation": {
                "border-beam": "border-beam calc(var(--duration)*1s) infinite linear"
              }
            }
          }
        }
      }
    },
    {
      "name": "retro-grid",
      "type": "registry:ui",
      "title": "Retro Grid",
      "description": "A perspective grid background effect with retro aesthetics.",
      "files": [
        {
          "path": "src/components/ui/retro-grid.tsx",
          "type": "registry:ui"
        }
      ],
      "registryDependencies": ["cn"],
      "tailwind": {
        "config": {
          "theme": {
            "extend": {
              "keyframes": {
                "grid": {
                  "0%": { "transform": "translateY(-50%)" },
                  "100%": { "transform": "translateY(0)" }
                }
              },
              "animation": {
                "grid": "grid 120s linear infinite"
              }
            }
          }
        }
      }
    },
    {
      "name": "shimmer-button",
      "type": "registry:ui",
      "title": "Shimmer Button",
      "description": "A button with a rotating shimmer light effect.",
      "files": [
        {
          "path": "src/components/ui/shimmer-button.tsx",
          "type": "registry:ui"
        }
      ],
      "registryDependencies": ["cn"],
      "tailwind": {
        "config": {
          "theme": {
            "extend": {
              "keyframes": {
                "shimmer-slide": {
                  "to": { "transform": "translate(calc(100cqw - 100%), 0)" }
                },
                "spin-around": {
                  "0%": { "transform": "translateZ(0) rotate(0)" },
                  "15%, 35%": { "transform": "translateZ(0) rotate(90deg)" },
                  "65%, 85%": { "transform": "translateZ(0) rotate(270deg)" },
                  "100%": { "transform": "translateZ(0) rotate(360deg)" }
                }
              },
              "animation": {
                "shimmer-slide": "shimmer-slide var(--speed) ease-in-out infinite alternate",
                "spin-around": "spin-around calc(var(--speed) * 2) infinite linear"
              }
            }
          }
        }
      }
    },
    {
      "name": "dock",
      "type": "registry:ui",
      "title": "Dock",
      "description": "A macOS-style dock with magnification effect on hover.",
      "files": [
